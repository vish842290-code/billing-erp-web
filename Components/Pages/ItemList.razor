@page "/itemlist"
@using Npgsql
@rendermode InteractiveServer

<div style="padding: 20px; max-width: 1100px; margin: auto; font-family: Arial, sans-serif;">
    <h2 style="color: #e65100; border-bottom: 2px solid #ffcc80; padding-bottom: 10px;">📦 Live Product Stock & Pricing</h2>

    <div style="background: #fff3e0; padding: 20px; border-radius: 8px; margin-bottom: 30px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
        <h4 style="margin-top: 0; color: #e65100;">@(isEditing ? "✏️ Edit Product Info" : "➕ Add New Product to Stock")</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px;">
            <div>
                <label>Product Name *</label>
                <input @bind="currentItem.Name" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;" placeholder="जैसे: Brinjal Hybrid Seeds" />
            </div>
            <div>
                <label>Stock Qty (Box/Piece) *</label>
                <input type="number" @bind="currentItem.Stock" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;" />
            </div>
            <div>
                <label>Purchase Price (खरीद मूल्य) *</label>
                <input type="number" @bind="currentItem.PurchasePrice" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;" placeholder="₹" />
            </div>
            <div>
                <label>Sale Price (बिक्री मूल्य) *</label>
                <input type="number" @bind="currentItem.Price" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;" placeholder="₹" />
            </div>
        </div>
        <div style="margin-top: 15px;">
            <button @onclick="SaveItem" style="background: #e65100; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-weight: bold;">@(isEditing ? "Update Changes" : "Add Product")</button>
            @if (isEditing)
            {
                <button @onclick="CancelEdit" style="background: #757575; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; margin-left: 10px;">Cancel</button>
            }
        </div>
        @if (!string.IsNullOrEmpty(msg)) { <p style="color: green; margin-top: 10px; font-weight: bold;">@msg</p> }
    </div>

    <h4 style="color: #333;">Current Inventory Master List</h4>
    <table style="width: 100%; border-collapse: collapse; margin-top: 10px; background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
        <thead>
            <tr style="background: #e65100; color: white; text-align: left;">
                <th style="padding: 12px; border: 1px solid #ddd;">Product Name</th>
                <th style="padding: 12px; border: 1px solid #ddd; text-align: center;">Stock Available</th>
                <th style="padding: 12px; border: 1px solid #ddd;">Purchase Rate</th>
                <th style="padding: 12px; border: 1px solid #ddd;">Sale Rate</th>
                <th style="padding: 12px; border: 1px solid #ddd; text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in items)
            {
                <tr style="border-bottom: 1px solid #ddd; background: @(item.Stock <= 5 ? "#ffebee" : "white")">
                    <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold;">@item.Name</td>
                    <td style="padding: 12px; border: 1px solid #ddd; text-align: center; font-weight: bold; color: @(item.Stock <= 5 ? "red" : "green")">@item.Stock Pcs</td>
                    <td style="padding: 12px; border: 1px solid #ddd;">₹@item.PurchasePrice</td>
                    <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold; color: #0d47a1;">₹@item.Price</td>
                    <td style="padding: 12px; border: 1px solid #ddd; text-align: center;">
                        <button @onclick="() => StartEdit(item)" style="background: #29b6f6; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-right: 5px;">✏️ Edit</button>
                        <button @onclick="() => DeleteItem(item.Id)" style="background: #ef5350; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">🗑️ Del</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private string connectionString = "Server=aws-1-ap-south-1.pooler.supabase.com;Port=6543;Database=postgres;User Id=postgres.frhqmjirwjokopemtjol;Password=aA1@VISHAL12;SslMode=Require;TrustServerCertificate=True;";
    
    private List<ItemModel> items = new();
    private ItemModel currentItem = new();
    private bool isEditing = false;
    private string msg = "";

    protected override async Task OnInitializedAsync() { await LoadItems(); }

    private async Task LoadItems()
    {
        items.Clear();
        using var conn = new NpgsqlConnection(connectionString);
        await conn.OpenAsync();
        
        

        using var cmd = new NpgsqlCommand("SELECT id, name, stock, price, purchase_price FROM items ORDER BY name ASC", conn);
        using var reader = await cmd.ExecuteReaderAsync();
        while (await reader.ReadAsync())
        {
            items.Add(new ItemModel {
                Id = reader.GetInt32(0),
                Name = reader.GetString(1),
                Stock = reader.GetInt32(2),
                Price = reader.GetDecimal(3),
                PurchasePrice = reader.GetDecimal(4)
            });
        }
    }

    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(currentItem.Name)) { msg = "नाम डालना अनिवार्य है!"; return; }

        using var conn = new NpgsqlConnection(connectionString);
        await conn.OpenAsync();

        if (isEditing)
        {
            using var cmd = new NpgsqlCommand("UPDATE items SET name=@name, stock=@stock, price=@price, purchase_price=@p_price WHERE id=@id", conn);
            cmd.Parameters.AddWithValue("@name", currentItem.Name.Trim());
            cmd.Parameters.AddWithValue("@stock", currentItem.Stock);
            cmd.Parameters.AddWithValue("@price", currentItem.Price);
            cmd.Parameters.AddWithValue("@p_price", currentItem.PurchasePrice);
            cmd.Parameters.AddWithValue("@id", currentItem.Id);
            await cmd.ExecuteNonQueryAsync();
            msg = "प्रोडक्ट में बदलाव सुरक्षित हो गए!";
        }
        else
        {
            using var cmd = new NpgsqlCommand("INSERT INTO items (name, stock, price, purchase_price) VALUES (@name, @stock, @price, @p_price)", conn);
            cmd.Parameters.AddWithValue("@name", currentItem.Name.Trim());
            cmd.Parameters.AddWithValue("@stock", currentItem.Stock);
            cmd.Parameters.AddWithValue("@price", currentItem.Price);
            cmd.Parameters.AddWithValue("@p_price", currentItem.PurchasePrice);
            await cmd.ExecuteNonQueryAsync();
            msg = "नया管प्रोडक्ट स्टॉक में जुड़ गया!";
        }

        CancelEdit();
        await LoadItems();
    }

    private void StartEdit(ItemModel item)
    {
        currentItem = new ItemModel { Id = item.Id, Name = item.Name, Stock = item.Stock, Price = item.Price, PurchasePrice = item.PurchasePrice };
        isEditing = true;
        msg = "";
    }

    private void CancelEdit()
    {
        currentItem = new ItemModel();
        isEditing = false;
    }

    private async Task DeleteItem(int id)
    {
        using var conn = new NpgsqlConnection(connectionString);
        await conn.OpenAsync();
        using var cmd = new NpgsqlCommand("DELETE FROM items WHERE id=@id", conn);
        cmd.Parameters.AddWithValue("@id", id);
        await cmd.ExecuteNonQueryAsync();
        msg = "प्रोडक्ट लिस्ट से हटा दिया गया!";
        await LoadItems();
    }

    public class ItemModel { public int Id { get; set; } public string Name { get; set; } = ""; public int Stock { get; set; } = 0; public decimal Price { get; set; } = 0; public decimal PurchasePrice { get; set; } = 0; }
}